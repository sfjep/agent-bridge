{
  "name": "agent-bridge",
  "version": "2.0.0",
  "description": "Distill cross-agent session history (Claude Code, Antigravity, Cursor, Codex) into a portable handoff file, with zero LLM tokens",
  "main": "build/index.js",
  "bin": {
    "agent-bridge": "./build/index.js"
  },
  "type": "module",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "pull": "node build/index.js pull",
    "list": "node build/index.js list"
  },
  "keywords": [
    "ai",
    "agents",
    "claude-code",
    "cursor",
    "antigravity",
    "context",
    "handoff",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}
